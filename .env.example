# ─────────────────────────────────────────────────────────────
# JobRadar — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# ─── Supabase (required) ─────────────────────────────────────
# Create a free project at https://supabase.com — copy from Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App-level encryption key for stored API keys (required) ──
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── App URL ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Anthropic Claude API (required for AI features) ─────────
# Get yours at https://console.anthropic.com
# Can also be configured per-user via the AI Settings page
ANTHROPIC_API_KEY=

# ─── AI Stub Mode ────────────────────────────────────────────
# Set to "true" to use stub responses without calling Claude.
# Useful for local dev without an API key.
AI_STUB_MODE=false

# ─── Adzuna API (primary job source) ─────────────────────────
# Free at https://developer.adzuna.com — 250 req/day
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# ─── Apify (LinkedIn + Indeed scraping) ──────────────────────
# Free $5/month credits at https://apify.com
APIFY_API_TOKEN=

# ─── Resend (daily email digest, optional) ───────────────────
# Free tier at https://resend.com
RESEND_API_KEY=
DIGEST_FROM_EMAIL=noreply@jobradar.app
