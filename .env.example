# ─────────────────────────────────────────────────────────────
# JobRadar — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# Database
# Local development (SQLite — default, no setup needed):
DATABASE_URL="file:./jobradar.db"
# Vercel / Production (PostgreSQL via Neon — see README):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Claude API (for resume parsing, match scoring, cover letters)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Adzuna API — primary job source (free tier, 250 req/day)
# Register at: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Adzuna country code (us, gb, au, ca, de, fr, etc.)
ADZUNA_COUNTRY=us

# Apify — LinkedIn + Indeed scraping (~$5/month free credits)
# Register at: https://apify.com
APIFY_API_TOKEN=

# Email digest — Resend (optional)
# Get your key at: https://resend.com
RESEND_API_KEY=
# Email address to send daily digest to:
DIGEST_EMAIL_TO=

# App base URL (used for links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
